{
  "name": "shagya-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:services": "docker compose -f infra/dev-services.yml up -d",
    "dev:services:down": "docker compose -f infra/dev-services.yml down",
    "dev:services:reset": "docker compose -f infra/dev-services.yml down -v",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@payloadcms/db-postgres": "^3.39.0",
    "@payloadcms/next": "^3.39.0",
    "@payloadcms/plugin-form-builder": "^3.39.0",
    "@payloadcms/plugin-seo": "^3.39.0",
    "@payloadcms/richtext-lexical": "^3.39.0",
    "@payloadcms/storage-s3": "^3.39.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "lucide-react": "^0.511.0",
    "next": "^16.1.1",
    "payload": "^3.39.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.1.0"
}
