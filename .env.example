# =============================================================================
# Shagya — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# --- Server ---
# The public URL of your Payload server (used for admin, API, and redirects)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Database (Neon Postgres) ---
# Option A: Docker (local dev) — start with `pnpm dev:services`
DATABASE_URL=postgres://shagya:shagya_dev@localhost:5432/shagya
# Option B: Neon (production / cloud dev)
# DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/shagya?sslmode=require

# --- Payload ---
# Secret key for encrypting JWT tokens, API keys, and sessions
# Generate: openssl rand -base64 32
PAYLOAD_SECRET=change-me-use-openssl-rand-base64-32

# --- Cloudflare R2 / S3-compatible Storage ---
# Option A: MinIO (local dev) — bundled with `make infra-up`
# Console: http://localhost:9001 (login: minioadmin / minioadmin)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=shagya-media
R2_REGION=us-east-1
# Option B: Cloudflare R2 (production / cloud dev)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=shagya-media
# R2_REGION=auto

# --- Resend (Transactional Email) ---
# Sign up: https://resend.com
# Free: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxx

# --- Better Auth (Customer Authentication) — Phase 2 ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# --- Razorpay (Payments) — Phase 3 ---
# Test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=change-me

# --- Optional: Analytics & Monitoring ---
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXX
# SENTRY_DSN=https://xxxx.ingest.sentry.io/xxxx
